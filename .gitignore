# Virtual Environment
venv/
ENV/
env/

# Environment variables (never commit secrets)
.env
.env.local
# .env.local.example should be committed — it contains only placeholders

# User-uploaded resume files (local dev)
data/user_resumes/

# Certificate and private key files
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# GCP service account and credential files
service_account*.json
*-service-account.json
credentials*.json
*-credentials.json

# IDE files
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Logs
logs/
*.log
npm-debug.log*

# Test / coverage output
.coverage
.coverage.*
coverage.xml
coverage.json
coverage_test_api.json
*.cover
htmlcov/
.pytest_cache/

# Database
*.sqlite3
*.db

# Temp files
tmp/
temp/

# Runtime directories — user uploads and server-generated files (never commit user data)
uploads/
generated/

# Private / cloud-specific files — infrastructure, CI/CD, internal docs
# All non-open-source content lives in _private/ and is never published
_private/

# Cloud-oriented env template — .env.local.example is the published template
.env.example

# Chrome Web Store publishing guide — kept locally for when/if submitting to the store
extension/PUBLISHING.md

# Frontend build output (generated by `npm run build` in ui/)
ui/node_modules/
ui/static/dist/

# Playwright E2E Tests
e2e/node_modules/
e2e/playwright-report/
e2e/test-results/
e2e/playwright/.auth/
e2e/dist/

# Local Just/Docker sandbox experiments (see `just sandbox-for-testing`)
sandbox-just-test/
