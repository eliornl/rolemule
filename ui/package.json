{
  "name": "rolemule-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Frontend asset build — esbuild (legacy JS/CSS) + Vite (TypeScript page entries)",
  "type": "module",
  "scripts": {
    "build": "node scripts/build-all.mjs",
    "build:legacy": "node build.mjs",
    "build:vite": "node scripts/build-vite.mjs",
    "build:watch": "node build.mjs --watch",
    "typecheck": "tsc --noEmit -p tsconfig.ci.json",
    "typecheck:all": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.3.1"
  }
}
