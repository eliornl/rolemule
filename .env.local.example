# ============================================================
# APPLYPILOT — LOCAL / SELF-HOSTED CONFIGURATION
# ============================================================
# You do not need to edit this file manually.
# Run:  make start
#
# make start will:
#   1. Copy this file to .env automatically (first run only)
#   2. Replace JWT_SECRET and ENCRYPTION_KEY with strong
#      random values
#   3. Start the app via Docker Compose
#
# After the app starts, add your Gemini API key in the UI:
#   Settings → AI Setup
# ============================================================

# ------------------------------------------------------------
# SECRETS — auto-generated by "make start" on first run.
# Do not set these manually unless you know what you're doing.
# ------------------------------------------------------------
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_AT_LEAST_32_CHARS
ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# LLM — per-user BYOK (Settings → AI Setup). Users pick gemini|openai|anthropic|ollama.
# LLM_PROVIDER is health/admin fallback only (not used for user generate paths).
# Vertex: USE_VERTEX_AI=true forces Gemini without user key.
# LLM_PROVIDER=gemini

# Optional server Gemini key — health/admin only under the per-user BYOK model
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# OpenAI (user BYOK in Settings; server key for health/admin when LLM_PROVIDER=openai)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.6-luna

# Anthropic (user BYOK in Settings; server key for health/admin when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5

# Ollama local / self-hosted (preferred_provider=ollama needs no user key)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen3

# ------------------------------------------------------------
# DATABASE & REDIS
# When using docker compose these are automatically overridden
# in docker-compose.yml to point at the postgres/redis containers.
# Only edit these if you run the app natively (without Docker).
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://applypilot:applypilot@localhost:5432/applypilot
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------
APP_NAME=ApplyPilot
DEBUG=true

# URL shown in password-reset and verification emails.
# Keep http://localhost:8000 for local use.
BASE_URL=http://localhost:8000

ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ORIGINS=http://localhost:8000

# ------------------------------------------------------------
# LOGGING
# "text" is human-readable for local dev; use "json" for prod.
# ------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_DIR=logs
LOG_FILE_ENABLED=false

# ------------------------------------------------------------
# JWT / BCRYPT
# ------------------------------------------------------------
JWT_EXPIRATION_HOURS=24
BCRYPT_ROUNDS=12

# ------------------------------------------------------------
# DEV SERVER (only used when running natively with make dev)
# ------------------------------------------------------------
RELOAD=true
WORKERS=1

# ------------------------------------------------------------
# GOOGLE OAUTH (optional)
# Leave commented out to disable Google sign-in.
# To enable: create credentials at https://console.cloud.google.com
#   → APIs & Services → Credentials → OAuth 2.0 Client IDs
#   Authorized redirect URI: http://localhost:8000/api/v1/auth/google/callback
# ------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------
# EMAIL / SMTP (optional)
# If SMTP is not configured, set DISABLE_EMAIL_VERIFICATION=true
# (below) so users can register and log in without a verification
# email. Password-reset emails also won't be sent without SMTP.
# Easiest setup: Gmail with an App Password
#   https://myaccount.google.com/apppasswords
# ------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# SMTP_FROM_EMAIL=your@gmail.com
# SMTP_FROM_NAME=ApplyPilot

# ------------------------------------------------------------
# SELF-HOSTED FLAGS
# ------------------------------------------------------------
# Relax rate limits for local Playwright E2E (register/login/API). Also set automatically
# by `make start-local`, `make dev`, and Playwright webServer — add here if you run
# uvicorn manually without those commands.
TESTING=true

# Skip email verification entirely — users are auto-verified on
# registration and can log in immediately without a verification code.
# Required when SMTP is not configured. Safe for personal/self-hosted
# use; do NOT set this on a public multi-user deployment.
DISABLE_EMAIL_VERIFICATION=true

# ------------------------------------------------------------
# ANALYTICS (optional — leave blank to disable)
# posthog_enabled defaults to True in settings.py, so explicitly
# set it to false here or PostHog tries to initialise on every page
# load even when no API key is provided.
# ------------------------------------------------------------
POSTHOG_ENABLED=false
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://us.i.posthog.com

# ------------------------------------------------------------
# NOT NEEDED FOR LOCAL USE
# (Cloud Tasks, Cloud Scheduler, Vertex AI — GCP only)
# ------------------------------------------------------------
USE_VERTEX_AI=false
