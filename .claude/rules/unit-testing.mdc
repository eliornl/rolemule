## Unit Test Pattern (`tests/test_agents/`)

```python
@pytest.fixture
def mock_gemini():
    with patch("agents.thank_you_writer.genai.Client") as mock:
        mock.return_value.models.generate_content = MagicMock(return_value=MockResponse(...))
        yield mock

class TestThankYouWriterAgent:
    @pytest.mark.asyncio
    async def test_generate_returns_expected_keys(self, mock_gemini):
        agent = ThankYouWriterAgent()
        result = await agent.generate(interviewer_name="Sarah", ...)
        assert "subject_line" in result
        assert "email_body" in result
```

